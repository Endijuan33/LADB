    <string name="error_waiting_title">Atascado en \"Esperando\"</string>
    <string name="error_waiting_summary">Puede que haya introducido la información de emparejamiento incorrectamente o
        que su dispositivo no esté siendo detectado. Primero, asegúrese de que la Depuración inalámbrica esté realmente
        habilitada. Si eso no funciona, pruebe la opción \"Restablecimiento de fábrica\" en LADB para intentar emparejar
        nuevamente.
    </string>

    <string name="error_no_wireless_debugging_title">No existe el interruptor \"Depuración inalámbrica\"</string>
    <string name="error_no_wireless_debugging_summary">Su dispositivo no admite de forma nativa la Depuración inalámbrica,
        la cual es requerida por LADB. Como alternativa, puede utilizar un PC para habilitar esta función, incluso en
        dispositivos no compatibles. Permanecerá habilitada hasta el próximo reinicio. Conecte el dispositivo a un PC y
        escriba: adb tcpip 5555
    </string>

